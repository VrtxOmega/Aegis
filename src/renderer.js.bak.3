    function restartPolling() {
        pollTimers.forEach(id => clearInterval(id));
        pollTimers = [];

        const polls = TAB_POLLS[activeTab] || [];
        polls.forEach(p => {
            p.fn();
            if (p.interval) {
                pollTimers.push(setInterval(p.fn, p.interval));
