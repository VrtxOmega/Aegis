{
  "name": "aegis",
  "version": "2.0.0",
  "description": "Aegis — System Security & Hardware Health",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.veritas.aegis",
    "productName": "Aegis",
    "win": {
      "icon": "src/assets/icon.ico",
      "target": "portable"
    },
    "portable": {
      "artifactName": "AegisProtect.exe"
    },
    "files": [
      "src/**/*",
      "backend/**/*",
      "!backend/__pycache__/**",
      "!backend/*.db"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": ["**/*", "!__pycache__/**", "!*.db"]
      }
    ],
    "asar": false
  },
  "keywords": [],
  "author": "RJ Lopez",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.1"
  }
}
